---
import Base from '../layouts/Base.astro';
import { ventures } from '../data/ventures';
---

<Base title="Adam Penn — Founder, Operator, Investor">
  <div class="container">

    <!-- Hero -->
    <section class="hero">
      <h1 class="animate-in delay-1">Adam Penn</h1>
      <p class="tagline animate-in delay-2">
        Engineer turned founder. I build and invest in real assets —
        with a bias toward long-term thinking, hands-on operations, and financial freedom.
      </p>
    </section>

    <!-- Ventures cards -->
    <section class="section animate-in delay-3">
      <div class="card-grid">
        {ventures.map(v => (
          <a href={v.url} target="_blank" rel="noopener" class="card" style="text-decoration: none;">
            <span class="card-label">{v.category}</span>
            <span class="card-title">{v.name}</span>
            <span class="card-desc">{v.oneLiner}</span>
            <span class="card-link">Visit</span>
          </a>
        ))}
      </div>
    </section>

    <!-- What I'm Building -->
    <section class="section animate-in delay-4">
      <span class="section-label">What I'm Building</span>
      <div style="max-width: 560px; display: flex; flex-direction: column; gap: 1.25rem;">
        <p>
          I spent the first chapter of my career writing software. It taught me how to think in systems,
          debug problems under pressure, and build things that actually work. Eventually I realized I
          wanted to apply that same mindset to something more tangible — so I started buying real estate.
        </p>
        <p>
          In 2017, I put $23,000 into my first property. Over the next several years, I used strategic
          debt and reinvested gains to grow that into a portfolio worth over $1.6 million. Along the way,
          I built the management company to run it, launched an investment fund to help others access
          similar strategies, and started a podcast about the whole process.
        </p>
        <p>
          I'm not chasing scale for its own sake. I'm building toward independence — the kind that
          comes from owning what you operate and aligning your work with how you want to live.
        </p>
      </div>
    </section>

    <!-- Principles -->
    <section class="section animate-in delay-5">
      <span class="section-label">Principles</span>
      <ul class="principles-list">
        <li>Think in decades, not quarters. The best returns come from patience and compounding.</li>
        <li>Own the operations. If you don't understand how the machine works, you don't really own it.</li>
        <li>Freedom is the real metric. Revenue means nothing if you've built yourself a cage.</li>
        <li>Stay close to the asset. Real wealth comes from real things — not abstractions.</li>
        <li>Build systems, not just deals. A good system outlasts any single opportunity.</li>
        <li>Say no more than you say yes. Discipline is a competitive advantage.</li>
        <li>Integrity compounds too. How you operate matters as much as what you build.</li>
      </ul>
    </section>

    <!-- Now -->
    <section class="section animate-in delay-6">
      <span class="section-label">Now</span>
      <div class="now-block">
        <p>
          Right now I'm focused on growing the Bidwell Capital Fund, improving operational systems
          across the Penn Properties portfolio, and recording new episodes of the Wealth Independence
          Podcast. I'm also spending more time thinking about how to structure businesses around
          the life you actually want — not the other way around.
        </p>
        <p style="font-size: 0.8rem; color: var(--text-tertiary); margin-top: 0.75rem;">
          Last updated: Q1 2026
        </p>
      </div>
    </section>

  </div>
</Base>
